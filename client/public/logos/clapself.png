			<script>jQuery(document).ready(function($) {
    function autoDetectAndFillLocation() {
        $.get('https://ipapi.co/json/', function(data) {
            if (data) {

                if (data.country_code) {
                    var userCountry = data.country_code.toLowerCase();
                    var $phoneField = $('input[name="phone-1"]');
                    
                    if ($phoneField.length) {
                        if (typeof $.fn.intlTelInput === 'function') {
                            $phoneField.intlTelInput("setCountry", userCountry);
                        } 
                        else if (window.intlTelInputGlobals) {
                            var iti = window.intlTelInputGlobals.getInstance($phoneField[0]);
                            if (iti) iti.setCountry(userCountry);
                        }
                    }
                }

                if ($('input[name="hidden-1"]').length) {
                    $('input[name="hidden-1"]').val(data.country_name);
                }
                if ($('input[name="hidden-2"]').length) {
                    $('input[name="hidden-2"]').val(data.city);
                }
            }
        });
    }
    $(document).on('after.load.forminator', function() {
        setTimeout(autoDetectAndFillLocation, 800); 
    });
});
</script><link rel="icon" href="https://everrest.org/wp-content/uploads/2023/10/cropped-photo_2023-07-18_15-53-27-32x32.jpg" sizes="32x32" />
