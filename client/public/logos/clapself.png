/* ---------------- */
form#forminator-module-1122 {
    background-color: #131722 !important;
    border: none !important; 
    border-radius: 16px !important;
    padding: 5px !important;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2) !important; 
}
form#forminator-module-1122 .forminator-input {
    background-color: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important; 
    border-radius: 8px !important;
    color: #ffffff !important;
    padding: 16px 20px !important;
    font-size: 16px !important;
    transition: all 0.3s ease !important;
    box-shadow: none !important;
}

form#forminator-module-1122 .forminator-input:focus {
    border-color: #5b5fd8 !important; 
    background-color: rgba(255, 255, 255, 0.06) !important;
    box-shadow: 0 0 0 3px rgba(91, 95, 216, 0.2) !important; 
}


form#forminator-module-1122 .forminator-input::placeholder {
    color: rgba(255, 255, 255, 0.3) !important;
}

form#forminator-module-1122 .forminator-label {
    color: #e2e8f0 !important;
    font-weight: 500 !important;
    font-size: 14px !important;
    margin-bottom: 8px !important;
}


form#forminator-module-1122 .forminator-required {
    color: #4cd4ff !important; 
}

form#forminator-module-1122 h4.forminator-label {
    color: #a0aec0 !important;
    font-size: 13px !important;
    line-height: 1.5 !important;
    margin-bottom: 15px !important;
    font-weight: 400 !important;
}

form#forminator-module-1122 span.forminator-checkbox-label {
    color: #ffffff !important;
    font-weight: 500 !important;
    margin-left: 5px !important;
}

form#forminator-module-1122 .forminator-checkbox-box {
    border-color: rgba(255, 255, 255, 0.2) !important;
    background-color: rgba(255, 255, 255, 0.03) !important;
    border-radius: 4px !important;
}


form#forminator-module-1122 .forminator-button-submit {
    background: linear-gradient(90deg, #5b5fd8, #2f43a7) !important;
    color: #ffffff !important;
    border: none !important;
    border-radius: 8px !important;
    padding: 16px 30px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    width: 100% !important; 
    transition: transform 0.3s ease, box-shadow 0.3s ease !important;
    margin-top: 10px !important;
}


form#forminator-module-1122 .forminator-button-submit:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 20px rgba(91, 95, 216, 0.3) !important;
}


@media (max-width: 768px) {
    form#forminator-module-1122 {
        padding: 25px !important;
    }
}

form#forminator-module-1122 .forminator-field {
    padding-top: 0 !important;
    margin-bottom: 20px !important;
}

form#forminator-module-1122 .forminator-label.forminator-floating--input {
    position: relative !important;
    top: 0 !important;
    left: 0 !important;
    transform: none !important;
    display: block !important;
    padding: 0 !important;
    margin-bottom: 8px !important;
    color: #e2e8f0 !important;
    background: transparent !important;
}


form#forminator-module-1122 .forminator-input--wrap:after,
form#forminator-module-1122 .forminator-input--wrap:before {
    display: none !important;
}		</style>
		
